{
  "name": "NYANNAPP",
  "version": "0.0.20",
  "description": "NYANN APP Project — PSO2 NGS Live Chat Text-to-Speech",
  "author": "BigCuteDonut",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.nyannlctts",
    "productName": "NYANNAPP",
    "artifactName": "NYANNAPP-Setup-${version}.${ext}",
    "publish": {
      "provider": "github",
      "owner": "ruunyann",
      "repo": "nyannlctts"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    },
    "directories": {
      "output": "release"
    },
    "extraResources": [
      {
        "from": "app_files/NYANNAPP.html",
        "to": "app.asar.unpacked/app/NYANNAPP.html"
      },
      {
        "from": "icon.ico",
        "to": "app.asar.unpacked/app/icon.ico"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/express/**",
      "node_modules/socket.io/**",
      "node_modules/socket.io-adapter/**",
      "node_modules/socket.io-parser/**",
      "node_modules/engine.io/**",
      "node_modules/engine.io-parser/**",
      "node_modules/accepts/**",
      "node_modules/cors/**",
      "node_modules/ws/**"
    ]
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "express": "^4.19.2",
    "socket.io": "^4.7.4"
  }
}
